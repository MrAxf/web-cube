---
import { twMerge } from "tailwind-merge";

// eslint-disable-next-line @typescript-eslint/no-unused-vars
interface Props {
  class?: string;
  id?: string;
}

const { class: className = "", id = "theme-button" } = Astro.props;
---

<button
  id={id}
  class:list={twMerge("icon-button shrink-0", className)}
  aria-label="Toggle theme"
  title="Toggle theme"
  data-theme-button
>
  <span class="transition-transform duration-300 inline-block"></span>
</button>

<script is:inline define:vars={{ id }}>
  const icon = (theme) =>
    theme === "dark" ? "i-heroicons-sun" : "i-heroicons-moon";

  const syncButton = ($themeButton) => {
    const theme = localStorage.getItem("theme") ?? "light";
    const $icon = $themeButton.querySelector("span");
    $icon.className = `transition-transform duration-300 inline-block ${icon(theme)}`;
  };

  const init = () => {
    const $themeButton = document.getElementById(id);
    if (!$themeButton) return;
    if ($themeButton.dataset.initialized === "true") {
      syncButton($themeButton);
      return;
    }
    $themeButton.dataset.initialized = "true";

    syncButton($themeButton);

    $themeButton.addEventListener("click", () => {
      $themeButton.style.transform = "rotate(180deg)";
      document.documentElement.classList.toggle("dark");
      const theme = document.documentElement.classList.contains("dark")
        ? "dark"
        : "light";
      localStorage.setItem("theme", theme);
      setTimeout(() => {
        $themeButton.style.transform = "rotate(0deg)";
      }, 150);
      syncButton($themeButton);
    });
  };
  init();
  document.addEventListener("astro:after-swap", init);
</script>
