<button
  id="search-button"
  class="flex h-4 shrink-0 cursor-pointer items-center gap-4 opacity-70 transition-opacity duration-200 hover:opacity-90 active:opacity-100 md:h-6 lg:h-8"
  aria-label="Search"
  title="Search"
>
  <span class="i-heroicons-magnifying-glass text-xl md:text-2xl lg:text-3xl"
  ></span>

  <!-- A kbd with (meta key + k) -->
  <span
    data-kbd
    class="hidden rounded-sm border border-slate-300 dark:border-slate-600 bg-slate-200 dark:bg-slate-800 px-2 py-1 text-xs font-mono md:block transition-colors"
    >Ctrl K</span
  >
</button>

<script>
  const init = () => {
    // @ts-ignore
    if (/(Mac|iPhone|iPod|iPad)/i.test(navigator.userAgent.platform)) {
      document.querySelector("[data-kbd]")!.textContent = "⌘ K";
    }
  };
  init();
  document.addEventListener("astro:after-swap", init);
</script>
