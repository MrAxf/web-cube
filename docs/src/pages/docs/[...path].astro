---
import { getCollection, render } from "astro:content";

import Footer from "@/components/footer.astro";
import PageNavigation from "@/components/page-navigation.astro";
import SideNavigation from "@/components/side-navigation.astro";
import BaseLayout from "@/layouts/base-layout.astro";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs
    .sort(
      (a, b) =>
        a.data.groupOrder - b.data.groupOrder || a.data.order - b.data.order,
    )
    .map((doc, idx) => ({
      params: { path: doc.data.path },
      props: {
        doc,
        prevDoc: docs[idx - 1] || undefined,
        nextDoc: docs[idx + 1] || undefined,
        docs,
      },
    }));
}

const { doc, prevDoc, nextDoc } = Astro.props;
const { Content, headings } = await render(doc);
---

<BaseLayout title={doc.data.title} mainClass="gap-12 flex flex-col py-0">
  <section class="flex justify-between gap-4">
    <SideNavigation />
    <article class="text-content-sm mx-auto w-full grow py-6 px-4 md:py-8 md:px-6 lg:px-8">
      <h1>{doc.data.title}</h1>
      <Content />
      <div
        class="not-prose my-8 flex flex-col sm:flex-row flex-wrap items-stretch justify-between gap-4 sm:gap-6"
      >
        {
          prevDoc && (
            <a
              href={`/docs/${prevDoc.data.path}`}
              class="no-prose box-content flex flex-1 items-center justify-start gap-3 rounded-lg border border-slate-300 dark:border-slate-600 px-4 py-3 no-underline opacity-70 shadow-sm transition-all duration-200 hover:opacity-100 hover:shadow-md"
            >
              <span class="i-heroicons-arrow-left" />
              <span class="text-sm sm:text-base line-clamp-2">{prevDoc.data.title}</span>
            </a>
          )
        }
        {
          nextDoc && (
            <a
              href={`/docs/${nextDoc.data.path}`}
              class="no-prose box-content flex flex-1 items-center justify-end gap-3 rounded-lg border border-slate-300 dark:border-slate-600 px-4 py-3 no-underline opacity-70 shadow-sm transition-all duration-200 hover:opacity-100 hover:shadow-md"
            >
              <span class="text-sm sm:text-base line-clamp-2 text-right">{nextDoc.data.title}</span>
              <span class="i-heroicons-arrow-right" />
            </a>
          )
        }
      </div>
      <Footer />
    </article>
    <PageNavigation headings={headings} />
  </section>
</BaseLayout>
